{
  "name": "rainfall-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A polished UK Environment Agency rainfall dashboard for Cloudflare Workers.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
